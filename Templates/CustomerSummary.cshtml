
@using OrdersApi.Dtos 
 @model CustomerDto
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Customer Lookup</title>

    <!-- Bootstrap 5 -->
    <link 
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" 
        rel="stylesheet"
    >
</head>

<body class="bg-light">

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <form onsubmit="alert('Form submitted!')"  class="p-4 bg-white shadow-sm rounded">

                <h4 class="mb-4 text-center">Customer Lookup</h4>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Name</label>
                    <input type="text" class="form-control" name="@Model.customerName" placeholder="Enter name">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" class="form-control" name="@Model.customerEmail" placeholder="Enter email">
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Submit
                </button>
            </form>
        </div>
    </div>
</div>
</body>
</html>